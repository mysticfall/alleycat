{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "main": {
      "disable": true
    }
  },
  "lsp": {
    "gdscript": {
      "command": [
        "godot-lsp-bridge",
        "--project",
        "game"
      ],
      "extensions": [
        ".gd",
        ".gdshader"
      ]
    }
  },
  "mcp": {
    "blender": {
      "type": "local",
      "command": [
        "uv",
        "--directory",
        "{env:BLENDER_MCP_HOME}",
        "run",
        "blender-mcp"
      ]
    }
  }
}
